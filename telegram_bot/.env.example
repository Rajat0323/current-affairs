# ─────────────────────────────────────────────────────────────
# UPSC Current Affairs Bot — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# NewsAPI key — get a free key at https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# Telegram Bot Token — create a bot via @BotFather on Telegram
# Example: 7123456789:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram Channel ID where messages will be sent.
# For a public channel: @yourchannel
# For a private channel: -100xxxxxxxxxx (get it from @userinfobot)
TELEGRAM_CHANNEL_ID=@your_channel_id

# Optional: OpenAI API key for smarter content formatting
# Leave blank to use the built-in rule-based formatter (works fine for most use cases)
OPENAI_API_KEY=
