TELEGRAM_BOT_TOKEN=123456789:your-telegram-bot-token
TELEGRAM_CHANNEL_ID=@your_channel_username
TELEGRAM_GROUP_ID=

NEWS_API_KEY=your-news-api-key
NEWS_API_URL=https://newsapi.org/v2/everything
CURRENT_AFFAIRS_QUERY=India OR government OR parliament OR economy OR summit OR diplomacy OR science OR sports
NEWS_LANGUAGE=en
NEWS_PAGE_SIZE=10
MAX_ARTICLES_PER_CYCLE=2
REQUEST_TIMEOUT_SECONDS=30
STATE_FILE=data/posted_articles.json

OPENAI_API_KEY=your-llm-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

TELEGRAM_SEND_MCQ_POLLS=true
MCQS_PER_ARTICLE=3

